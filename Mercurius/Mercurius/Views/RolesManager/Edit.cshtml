@model Microsoft.AspNetCore.Identity.IdentityRole

@{
    ViewData["Title"] = "Edit Role";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var pages = ViewBag.pages as List<Mercurius.Models.PageSelectItem> ?? new List<Mercurius.Models.PageSelectItem>();
}

<style>
    .page-checkbox {
        transition: all 0.2s ease;
    }
    .page-checkbox:hover {
        background-color: #f8f9fa;
        border-radius: 4px;
    }
    .page-checkbox.hidden {
        display: none !important;
    }
    .search-highlight {
        background-color: #fff3cd;
        padding: 0 2px;
        border-radius: 2px;
        font-weight: bold;
    }
    .pages-container {
        max-height: 500px;
        overflow-y: auto;
    }
    .select-all-btns {
        margin-bottom: 15px;
    }
</style>

<!-- PAGE TITLE -->
<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
    <div id="kt_app_toolbar_container" class="app-container container-xxl d-flex flex-stack">
        <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
            <h1 class="page-heading d-flex text-dark fw-bold fs-3 flex-column justify-content-center my-0">Edit Role: @Model.Name</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                <li class="breadcrumb-item text-muted">
                    <a href="/" class="text-muted text-hover-primary">Home</a>
                </li>
                <li class="breadcrumb-item">
                    <span class="bullet bg-gray-400 w-5px h-2px"></span>
                </li>
                <li class="breadcrumb-item text-muted">
                    <a href="/RolesManager" class="text-muted text-hover-primary">Roles</a>
                </li>
                <li class="breadcrumb-item">
                    <span class="bullet bg-gray-400 w-5px h-2px"></span>
                </li>
                <li class="breadcrumb-item text-muted">Edit</li>
            </ul>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-10">
        <form asp-action="Edit" id="roleEditForm">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="row mb-5">
                <div class="col-md-6">
                    <label asp-for="Name" class="fs-6 fw-semibold form-label mt-3">
                        <span class="required">Role Name</span>
                    </label>
                    <input asp-for="Name" type="text" class="form-control form-control-lg" readonly>
                    <span asp-validation-for="Name" class="text-danger"></span>
                    <small class="text-muted">Role name cannot be changed</small>
                </div>
            </div>

            <div class="separator border-gray-200 pt-5 mb-5"></div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <label class="fs-6 fw-bold form-label mb-0">
                    <span class="required">Access to Pages</span>
                    <span class="text-muted fs-7 ms-2">(<span id="selectedCount">0</span> of <span id="totalCount">0</span> selected)</span>
                </label>
                
                <!-- Search Box -->
                <div class="d-flex gap-3">
                    <div class="position-relative">
                        <span class="svg-icon svg-icon-2 svg-icon-gray-500 position-absolute top-50 translate-middle-y ms-4">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect opacity="0.5" x="17.0365" y="15.1223" width="8.15546" height="2" rx="1" transform="rotate(45 17.0365 15.1223)" fill="currentColor"/>
                                <path d="M11 19C6.55556 19 3 15.4444 3 11C3 6.55556 6.55556 3 11 3C15.4444 3 19 6.55556 19 11C19 15.4444 15.4444 19 11 19ZM11 5C7.53333 5 5 7.53333 5 11C5 14.4667 7.53333 17 11 17C14.4667 17 17 14.4667 17 11C17 7.53333 14.4667 5 11 5Z" fill="currentColor"/>
                            </svg>
                        </span>
                        <input type="text" id="pageSearch" class="form-control form-control-solid ps-12" placeholder="Search pages..." style="min-width: 300px;">
                        <button type="button" id="clearSearch" class="btn btn-icon btn-sm btn-active-light-primary position-absolute top-50 translate-middle-y end-0 me-2" style="display: none;">
                            <span class="svg-icon svg-icon-1">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <rect opacity="0.5" x="6" y="17.3137" width="16" height="2" rx="1" transform="rotate(-45 6 17.3137)" fill="currentColor"/>
                                    <rect x="7.41422" y="6" width="16" height="2" rx="1" transform="rotate(45 7.41422 6)" fill="currentColor"/>
                                </svg>
                            </span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Select All / None Buttons -->
            <div class="select-all-btns">
                <button type="button" class="btn btn-sm btn-light-primary me-2" id="selectAllVisible">
                    <span class="svg-icon svg-icon-2 svg-icon-primary me-1">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path opacity="0.3" d="M5 16C3.34315 16 2 14.6569 2 13V6C2 4.34315 3.34315 3 5 3H13C14.6569 3 16 4.34315 16 6V7H15V6C15 4.89543 14.1046 4 13 4H5C3.89543 4 3 4.89543 3 6V13C3 14.1046 3.89543 15 5 15H12C13.1046 15 14 14.1046 14 13V11H15V13C15 14.6569 13.6569 16 12 16H5Z" fill="currentColor"/>
                            <path d="M20 10V18C20 19.6569 18.6569 21 17 21H9C7.34315 21 6 19.6569 6 18V10C6 8.34315 7.34315 7 9 7H17C18.6569 7 20 8.34315 20 10Z" fill="currentColor"/>
                        </svg>
                    </span>
                    Select All Visible
                </button>
                <button type="button" class="btn btn-sm btn-light-danger me-2" id="deselectAllVisible">
                    <span class="svg-icon svg-icon-2 svg-icon-danger me-1">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect opacity="0.3" x="4" y="4" width="16" height="16" rx="2" fill="currentColor"/>
                            <path d="M8 12L16 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </span>
                    Deselect All Visible
                </button>
                <button type="button" class="btn btn-sm btn-light-warning" id="selectAllPages">
                    <span class="svg-icon svg-icon-2 svg-icon-warning me-1">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm0-2a8 8 0 1 0 0-16 8 8 0 0 0 0 16zm-1-5h2v2h-2v-2zm0-8h2v6h-2V7z" fill="currentColor"/>
                        </svg>
                    </span>
                    Select All (@pages.Count)
                </button>
            </div>

            <!-- Pages Grid -->
            <div class="pages-container border rounded p-4 bg-light">
                <div class="row g-3" id="pagesGrid">
                    @foreach (var p in pages)
                    {
                        var displayName = p.PageId.Replace("_", " ");
                        <div class="col-12 col-sm-6 col-md-4 col-lg-3 page-checkbox-wrapper" data-page-name="@p.PageId.ToLower()" data-display-name="@displayName.ToLower()">
                            <div class="page-checkbox form-check form-check-custom form-check-solid p-3 border rounded bg-white">
                                <input type="checkbox" class="form-check-input page-checkbox-input" name="pages" value="@p.PageId" @(p.IsSelected ? "checked='checked'" : "") id="page_@p.PageId.Replace(".", "_")" data-display="@displayName">
                                <label class="form-check-label ms-2 text-break" for="page_@p.PageId.Replace(".", "_")">
                                    @displayName
                                </label>
                            </div>
                        </div>
                    }
                </div>
                <div id="noResults" class="text-center py-5 text-muted" style="display: none;">
                    <span class="svg-icon svg-icon-3x svg-icon-muted mb-3">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect opacity="0.5" x="17.0365" y="15.1223" width="8.15546" height="2" rx="1" transform="rotate(45 17.0365 15.1223)" fill="currentColor"/>
                            <path d="M11 19C6.55556 19 3 15.4444 3 11C3 6.55556 6.55556 3 11 3C15.4444 3 19 6.55556 19 11C19 15.4444 15.4444 19 11 19ZM11 5C7.53333 5 5 7.53333 5 11C5 14.4667 7.53333 17 11 17C14.4667 17 17 14.4667 17 11C17 7.53333 14.4667 5 11 5Z" fill="currentColor"/>
                        </svg>
                    </span>
                    <p>No pages found matching your search</p>
                </div>
            </div>

            <div class="separator border-gray-200 pt-5 mb-5"></div>

            <div class="d-flex flex-stack flex-wrap">
                <div class="my-1 me-5">
                    <a asp-action="Index" class="btn btn-light">
                        <span class="svg-icon svg-icon-2 me-1">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M11.2657 11.4343L15.45 7.25C15.8642 6.83579 15.8642 6.16421 15.45 5.75C15.0358 5.33579 14.3642 5.33579 13.95 5.75L8.40712 11.2929C8.01659 11.6834 8.01659 12.3166 8.40712 12.7071L13.95 18.25C14.3642 18.6642 15.0358 18.6642 15.45 18.25C15.8642 17.8358 15.8642 17.1642 15.45 16.75L11.2657 12.5657C10.9533 12.2533 10.9533 11.7467 11.2657 11.4343Z" fill="currentColor"/>
                            </svg>
                        </span>
                        Back to List
                    </a>
                </div>
                <div class="d-flex align-items-center gap-2 gap-lg-3">
                    <button type="submit" class="btn btn-primary">
                        <span class="svg-icon svg-icon-2 me-1">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path opacity="0.3" d="M10 18C9.7 18 9.5 17.9 9.3 17.7L4.3 12.7C3.9 12.3 3.9 11.7 4.3 11.3C4.7 10.9 5.3 10.9 5.7 11.3L10 15.6L18.3 7.3C18.7 6.9 19.3 6.9 19.7 7.3C20.1 7.7 20.1 8.3 19.7 8.7L10.7 17.7C10.5 17.9 10.3 18 10 18Z" fill="currentColor"/>
                                <path d="M10 18C9.7 18 9.5 17.9 9.3 17.7L4.3 12.7C3.9 12.3 3.9 11.7 4.3 11.3C4.7 10.9 5.3 10.9 5.7 11.3L10 15.6L18.3 7.3C18.7 6.9 19.3 6.9 19.7 7.3C20.1 7.7 20.1 8.3 19.7 8.7L10.7 17.7C10.5 17.9 10.3 18 10 18Z" fill="currentColor"/>
                            </svg>
                        </span>
                        Update Permissions
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            const $searchInput = $('#pageSearch');
            const $clearBtn = $('#clearSearch');
            const $pagesGrid = $('#pagesGrid');
            const $noResults = $('#noResults');
            const $selectedCount = $('#selectedCount');
            const $totalCount = $('#totalCount');

            // Initialize counts
            updateCounts();

            // Search functionality - search in display name (with spaces)
            $searchInput.on('input', function() {
                const rawSearch = $(this).val().toLowerCase().trim();
                filterPages(rawSearch);
                toggleClearButton(rawSearch);
            });

            // Clear search button
            $clearBtn.on('click', function() {
                $searchInput.val('');
                filterPages('');
                toggleClearButton('');
                $searchInput.focus();
            });

            // Select all visible
            $('#selectAllVisible').on('click', function() {
                $('.page-checkbox-wrapper:visible .page-checkbox-input').prop('checked', true);
                updateCounts();
            });

            // Deselect all visible
            $('#deselectAllVisible').on('click', function() {
                $('.page-checkbox-wrapper:visible .page-checkbox-input').prop('checked', false);
                updateCounts();
            });

            // Select ALL pages (including hidden)
            $('#selectAllPages').on('click', function() {
                $('.page-checkbox-input').prop('checked', true);
                updateCounts();
            });

            // Update counts when individual checkboxes change
            $(document).on('change', '.page-checkbox-input', function() {
                updateCounts();
            });

            function filterPages(searchTerm) {
                if (!searchTerm) {
                    // Show all - reset labels
                    $('.page-checkbox-wrapper').each(function() {
                        const $wrapper = $(this);
                        const originalText = $wrapper.find('.page-checkbox-input').data('display');
                        $wrapper.removeClass('hidden');
                        $wrapper.find('.form-check-label').text(originalText);
                    });
                    $noResults.hide();
                    $pagesGrid.show();
                    return;
                }

                let visibleCount = 0;

                $('.page-checkbox-wrapper').each(function() {
                    const $wrapper = $(this);
                    const $label = $wrapper.find('.form-check-label');
                    const originalText = $wrapper.find('.page-checkbox-input').data('display');
                    
                    // Convert to lowercase for case-insensitive search
                    const textLower = originalText.toLowerCase();
                    
                    // Check if text contains the search term
                    if (textLower.indexOf(searchTerm) !== -1) {
                        $wrapper.removeClass('hidden');
                        
                        // Highlight matching text
                        let highlighted = originalText;
                        const regex = new RegExp('(' + searchTerm.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
                        highlighted = originalText.replace(regex, '<span class="search-highlight">$1</span>');
                        
                        $label.html(highlighted);
                        visibleCount++;
                    } else {
                        $wrapper.addClass('hidden');
                    }
                });

                if (visibleCount === 0) {
                    $pagesGrid.hide();
                    $noResults.show();
                } else {
                    $pagesGrid.show();
                    $noResults.hide();
                }
            }

            function toggleClearButton(searchTerm) {
                if (searchTerm) {
                    $clearBtn.show();
                } else {
                    $clearBtn.hide();
                }
            }

            function updateCounts() {
                const total = $('.page-checkbox-input').length;
                const selected = $('.page-checkbox-input:checked').length;
                $selectedCount.text(selected);
                $totalCount.text(total);
            }

            // Form submission confirmation
            $('#roleEditForm').on('submit', function(e) {
                const selectedCount = $('.page-checkbox-input:checked').length;
                if (selectedCount === 0) {
                    if (!confirm('No pages are selected. This role will have no access. Continue?')) {
                        e.preventDefault();
                    }
                }
            });
        });
    </script>
}
