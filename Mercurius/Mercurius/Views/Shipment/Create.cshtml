@model Mercurius.Repo.Models.ShipmentArrival
@{
    ViewData["Title"] = "Add Shipment";
    var poId = Context.Request.Query["poId"].FirstOrDefault();
}

<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
    <div class="app-container container-xxl"><div class="page-title"><h1 class="page-heading d-flex text-dark fw-bold fs-3 my-0">Add Shipment</h1></div></div>
</div>

<div class="card">
    <div class="card-body p-10">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-5">
                <div class="col-md-6">
                    <label class="form-label required">Purchase Order</label>
                    <select asp-for="PurchaseOrderId" class="form-select form-select-sm" asp-items="ViewBag.PurchaseOrderId" id="po-select">
                        <option value="">-- Select PO --</option>
                    </select>
                    <div class="form-text">Supplier is auto-filled from the selected PO.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Supplier</label>
                    <input asp-for="SupplierId" type="hidden" id="supplier-id" />
                    <input type="text" class="form-control form-control-sm" id="supplier-name" readonly value="Auto-filled from PO" />
                </div>
                <div class="col-md-6">
                    <label asp-for="ShipmentArrivalDate" class="form-label required">Arrival Date</label>
                    <input asp-for="ShipmentArrivalDate" class="form-control form-control-sm" type="date" required />
                </div>
                <div class="col-md-6">
                    <label asp-for="ShipmentArrivalStatusId" class="form-label">Status</label>
                    <input asp-for="ShipmentArrivalStatusId" class="form-control form-control-sm" type="number" value="1" />
                </div>
                <div class="col-md-6">
                    <label asp-for="TrackingNumber" class="form-label">Tracking Number</label>
                    <input asp-for="TrackingNumber" class="form-control form-control-sm" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Location</label>
                    <input asp-for="LocationId" class="form-control form-control-sm" type="number" value="1" />
                </div>
                <div class="col-12">
                    <label asp-for="Notes" class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control form-control-sm" rows="2"></textarea>
                </div>
            </div>
            <div class="border-top d-flex flex-stack flex-wrap mt-8 pt-6">
                <a href="/Shipment" class="btn btn-light">Cancel</a>
                <button type="submit" class="btn btn-primary">Save Shipment</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            var poId = '@poId';
            if (poId) {
                $('#po-select').val(poId).trigger('change');
            }

            // When PO is selected, auto-fill supplier from PO
            $('#po-select').on('change', function () {
                var selectedPoId = $(this).val();
                if (selectedPoId) {
                    $.get('/Shipment/GetSupplierForPo?poId=' + selectedPoId, function (data) {
                        $('#supplier-id').val(data.supplierId);
                        $('#supplier-name').val(data.supplierName);
                    });
                } else {
                    $('#supplier-id').val('');
                    $('#supplier-name').val('Auto-filled from PO');
                }
            });
        });
    </script>
}
