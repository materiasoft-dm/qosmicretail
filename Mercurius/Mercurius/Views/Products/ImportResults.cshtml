@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Import Results";
    
    var importResults = ViewBag.ImportResults as List<Mercurius.Models.ImportResult>;
    var successCount = ViewBag.SuccessCount as int? ?? 0;
    var errorCount = ViewBag.ErrorCount as int? ?? 0;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
}

<!-- PAGE TITLE -->
<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
    <div id="kt_app_toolbar_container" class="app-container container-xxl d-flex flex-stack">   
        <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
            <h1 class="page-heading d-flex text-dark fw-bold fs-3 flex-column justify-content-center my-0">Import Results</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                <li class="breadcrumb-item text-muted">
                    <a href="/" class="text-muted text-hover-primary">Home</a>
                </li>
                <li class="breadcrumb-item">
                    <span class="bullet bg-gray-400 w-5px h-2px"></span>
                </li>
                <li class="breadcrumb-item text-muted">
                    <a href="/Products" class="text-muted text-hover-primary">Products</a>
                </li>
                <li class="breadcrumb-item">
                    <span class="bullet bg-gray-400 w-5px h-2px"></span>
                </li>
                <li class="breadcrumb-item text-muted">Import Results</li>
            </ul>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-10">
        <div class="alert @(errorCount > 0 ? "alert-warning" : "alert-success")">
            <h4 class="alert-heading">Import Summary</h4>
            <p>
                <strong>Total Records Processed:</strong> @totalCount<br />
                <strong>Successfully Imported/Updated:</strong> @successCount<br />
                <strong>Errors/Skipped:</strong> @errorCount<br />
                <strong>Success Rate:</strong> @(totalCount > 0 ? ((successCount * 100) / totalCount).ToString("0.00") : "0")%
            </p>
        </div>

        @if (errorCount > 0)
        {
            <div class="alert alert-danger">
                <h4 class="alert-heading">Some records had issues:</h4>
                <p>Check the table below for details on each record that failed or was skipped.</p>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-hover table-rounded table-striped border gy-7 gs-7">
                <thead>
                    <tr class="fw-bold fs-6 text-gray-800 border-bottom border-gray-200">
                        <th>Row</th>
                        <th>SKU/Handle</th>
                        <th>Product Name</th>
                        <th>Status</th>
                        <th>Result</th>
                    </tr>
                </thead>
                <tbody>
                    @if (importResults != null && importResults.Any())
                    {
                        foreach (var result in importResults)
                        {
                            <tr>
                                <td>@result.RowNumber</td>
                                <td>@result.Sku</td>
                                <td>@result.Name</td>
                                <td>@result.Status</td>
                                <td>
                                    @if (result.Status.Contains("Created") || result.Status.Contains("Updated"))
                                    {
                                        <span class="badge badge-light-success">Success</span>
                                    }
                                    else if (result.Status.Contains("Error"))
                                    {
                                        <span class="badge badge-light-danger">Error</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-light-warning">Skipped</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">No import results available.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="border-top d-flex flex-stack flex-wrap mt-lg-10 pt-13">
            <div class="my-1 me-5">
                <a href="/Products/Import" class="btn btn-light">Import Another File</a>
            </div>

            <div class="d-flex align-items-center gap-2 gap-lg-3">
                <a href="/Products" class="btn btn-primary">View Products</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Add search functionality
            $('table').DataTable({
                pageLength: 25,
                order: [[0, 'asc']],
                dom: '<"row"<"col-sm-12 col-md-6"l><"col-sm-12 col-md-6"f>>' +
                     '<"row"<"col-sm-12"tr>>' +
                     '<"row"<"col-sm-12 col-md-5"i><"col-sm-12 col-md-7"p>>',
                language: {
                    search: "Search results:",
                    searchPlaceholder: "Search by SKU, Name, or Status..."
                }
            });
        });
    </script>
}
