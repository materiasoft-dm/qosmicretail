    @await RenderSectionAsync("Scripts", required: false)
    @{
        // Flash messages — populated via either TempData (survives one redirect) or
        // ViewData (same-view re-render after validation failure). The companion
        // *Type keys carry "success" | "error" | "warning" | "info" — falls back to "info".
        // For backward compatibility we also pick up the older TempData["Message"] /
        // TempData["ProductCreated"] keys that several controllers set.
        var flashMessage = TempData["FlashMessage"] as string
                           ?? (ViewData["FlashMessage"] as string)
                           ?? (TempData["Message"] as string)
                           ?? (TempData["ProductCreated"] is string pc ? $"Product '{pc}' saved." : null);
        var flashType = (TempData["FlashType"] as string)
                        ?? (ViewData["FlashType"] as string)
                        ?? (flashMessage != null && TempData["ProductCreated"] != null ? "success" : null)
                        ?? "info";
    }
    <script>
        $(function () {
            // Toastr defaults — applied once per page load.
            if (typeof toastr !== 'undefined') {
                toastr.options = $.extend({}, toastr.options, {
                    closeButton: true,
                    progressBar: true,
                    positionClass: 'toastr-top-right',  // Metronic's bundled toastr uses 'toastr-*' class prefix, not vanilla 'toast-*'
                    timeOut: 5000,
                    extendedTimeOut: 2000,
                    newestOnTop: true,
                    preventDuplicates: true,
                    escapeHtml: true   // we render server-supplied strings; never trust them as HTML
                });
            }

            // Helper any view can call: showFlash('Saved.', 'success')
            window.showFlash = function (message, type) {
                if (typeof toastr === 'undefined' || !message) return;
                var fn = toastr[type] || toastr.info;
                fn.call(toastr, message);
            };

        @if (!string.IsNullOrWhiteSpace(flashMessage))
        {
            <text>
            window.showFlash(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(flashMessage)),
                             @Html.Raw(System.Text.Json.JsonSerializer.Serialize(flashType)));
            </text>
        }

            // Legacy ?message=... query-string handler — kept so existing links keep working.
            var querystringMessage = (new URL(location.href)).searchParams.get('message');
            if (querystringMessage !== null) {
                window.showFlash(querystringMessage, 'info');
                var uri = window.location.toString();
                if (uri.indexOf("?") > 0) {
                    var clean_uri = uri.substring(0, uri.indexOf("?"));
                    window.history.replaceState({}, document.title, clean_uri);
                }
            }

            // Pending flash from an AJAX-form redirect — see js-ajax-form handler below.
            try {
                var pending = sessionStorage.getItem('mercurius_pending_flash');
                if (pending) {
                    sessionStorage.removeItem('mercurius_pending_flash');
                    var parsed = JSON.parse(pending);
                    window.showFlash(parsed.message, parsed.type || 'info');
                }
            } catch (e) { /* ignore malformed flash */ }

            // ------------------------------------------------------------------
            // AJAX form submission. Opt-in: add class="js-ajax-form" to a <form>.
            // The server-side counterpart returns JSON like
            //   { ok: true,  redirect: "/Products", message: "Saved." }
            //   { ok: false, errors: ["PartCode is required", ...] }
            // when the request advertises Accept: application/json.
            // ------------------------------------------------------------------
            $(document).on('submit', 'form.js-ajax-form', function (e) {
                e.preventDefault();
                var $form = $(this);
                if ($form.data('mercurius-submitting')) return false;
                $form.data('mercurius-submitting', true);

                // Disable submit buttons to prevent double-submits & show spinner if Metronic-styled.
                var $buttons = $form.find('button[type="submit"], input[type="submit"]').prop('disabled', true);
                $buttons.filter('[data-kt-indicator]').attr('data-kt-indicator', 'on');

                var formData = new FormData(this);

                fetch($form.attr('action') || window.location.pathname, {
                    method: ($form.attr('method') || 'POST').toUpperCase(),
                    body: formData,
                    credentials: 'same-origin',
                    headers: {
                        // Tell the server we want JSON back. Don't set Content-Type —
                        // the browser sets multipart/form-data with the right boundary.
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                }).then(function (resp) {
                    var ct = resp.headers.get('content-type') || '';
                    // If the server somehow returned HTML (auth redirect, unhandled exception
                    // page, non-AJAX endpoint), fall back to a full submit.
                    if (!ct.includes('application/json')) {
                        if (resp.redirected) {
                            window.location.href = resp.url;
                            return null;
                        }
                        return resp.text().then(function () {
                            window.showFlash('Unexpected server response. Please try again.', 'error');
                            return null;
                        });
                    }
                    return resp.json();
                }).then(function (data) {
                    if (!data) return;
                    if (data.ok) {
                        if (data.message && data.redirect) {
                            // Stash so the destination page can show the toast after navigation.
                            try {
                                sessionStorage.setItem('mercurius_pending_flash',
                                    JSON.stringify({ message: data.message, type: 'success' }));
                            } catch (e) { /* ignore quota */ }
                        } else if (data.message) {
                            window.showFlash(data.message, 'success');
                        }
                        if (data.redirect) {
                            window.location.href = data.redirect;
                        } else {
                            // No redirect — re-enable form for further edits.
                            $buttons.prop('disabled', false);
                            $buttons.filter('[data-kt-indicator]').removeAttr('data-kt-indicator');
                        }
                    } else {
                        var errs = (data.errors && data.errors.length)
                            ? data.errors.join(' • ')
                            : (data.message || 'Save failed.');
                        window.showFlash(errs, 'error');
                        $buttons.prop('disabled', false);
                        $buttons.filter('[data-kt-indicator]').removeAttr('data-kt-indicator');
                    }
                }).catch(function (err) {
                    window.showFlash('Network error: ' + (err && err.message ? err.message : 'request failed.'), 'error');
                    $buttons.prop('disabled', false);
                    $buttons.filter('[data-kt-indicator]').removeAttr('data-kt-indicator');
                }).finally(function () {
                    $form.data('mercurius-submitting', false);
                });

                return false;
            });
        });

        function registerDataTable(selector) {
            //check if initialized already
            var isInitialized = $.fn.DataTable.isDataTable(selector);
            if (!isInitialized){
                $(selector).DataTable({
                    initComplete: function () {
                        this.api()
                            .columns()
                            .every(function () {
                                var column = this;
                                var select = $('<select><option value=""></option></select>')
                                    .appendTo($(column.header()).empty())
                                    .on('change', function () {
                                        var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                        column.search(val ? '^' + val + '$' : '', true, false).draw();
                                    });
                            });
                    }
                });
            }
        }
    </script>

    <!-- UTC to Local Time Converter — processes <time class="local-time" datetime="2026-05-19T10:30:00Z"> -->
    <script>
        (function () {
            function formatLocal(d) {
                return d.getFullYear() + '-' +
                    String(d.getMonth() + 1).padStart(2, '0') + '-' +
                    String(d.getDate()).padStart(2, '0') + ' ' +
                    String(d.getHours()).padStart(2, '0') + ':' +
                    String(d.getMinutes()).padStart(2, '0');
            }
            document.querySelectorAll('time.local-time').forEach(function (el) {
                var iso = el.getAttribute('datetime') || el.textContent.trim();
                var d = new Date(iso);
                if (!isNaN(d.getTime())) {
                    el.textContent = formatLocal(d);
                    el.setAttribute('title', 'UTC: ' + iso);
                }
            });
        })();
    </script>
</body>
