@model Mercurius.ViewComponents.Dashboard.MonthlyNewCustomersModel

<div class="card card-flush h-md-50 mb-xl-10 h-md-100">
    <div class="card-header pt-5">
        <div class="card-title d-flex flex-column">
            <span class="fs-2hx fw-bold text-dark me-2 lh-1 ls-n2">@Model.NewCustomersThisMonth</span>
            <span class="text-gray-400 pt-1 fw-semibold fs-6">New Customers This Month</span>
        </div>
    </div>
    <div class="card-body d-flex flex-column justify-content-end pe-0">
        <span class="fs-6 fw-bolder text-gray-800 d-block mb-2">New Customers</span>
        <div class="symbol-group symbol-hover flex-nowrap">
            @for (var i = 0; i < Model.TopCustomers.Count; i++)
            {
                var cust = Model.TopCustomers[i];
                var initial = string.IsNullOrEmpty(cust.FirstName) ? "?" : cust.FirstName.Substring(0, 1);
                <div class="symbol symbol-35px symbol-circle" data-bs-toggle="tooltip" title="@($"{cust.FirstName} {cust.LastName}")">
                    <span class="symbol-label text-inverse-warning fw-bold" style="background-color:@Model.ColorFor(i)">@initial</span>
                </div>
            }
        </div>
    </div>
</div>
