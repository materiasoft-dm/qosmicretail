@model IEnumerable<Mercurius.Repo.Models.CategoryField>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Category Custom Fields";
    var categories = ViewBag.Categories as Dictionary<int, string>;
}

<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
    <div id="kt_app_toolbar_container" class="app-container container-xxl d-flex flex-stack">
        <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
            <h1 class="page-heading d-flex text-dark fw-bold fs-3 flex-column justify-content-center my-0">Category Custom Fields</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                <li class="breadcrumb-item text-muted"><a href="/" class="text-muted text-hover-primary">Home</a></li>
                <li class="breadcrumb-item"><span class="bullet bg-gray-400 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-muted">Configurations</li>
                <li class="breadcrumb-item"><span class="bullet bg-gray-400 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-muted">Category Fields</li>
            </ul>
        </div>
        <div class="d-flex align-items-center gap-2 gap-lg-3">
            <a href="/Config/CategoryFields/Create" class="btn btn-primary">Add Field</a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body pt-0">
        <div class="table-responsive">
            <table id="fieldsTable" class="table table-hover table-rounded table-striped border gy-7 gs-7">
                <thead>
                    <tr class="fw-bold fs-6 text-gray-800 border-bottom border-gray-200">
                        <th>Category</th>
                        <th>Field Name</th>
                        <th>Display Label</th>
                        <th>Type</th>
                        <th>Required</th>
                        <th>Order</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var field in Model)
                    {
                        <tr>
                            <td>@(categories?.TryGetValue(field.CategoryId, out var name) == true ? name : field.CategoryId.ToString())</td>
                            <td><code>@field.FieldName</code></td>
                            <td>@field.DisplayLabel</td>
                            <td><span class="badge badge-light-info">@field.FieldType</span></td>
                            <td>@(field.IsRequired ? "Yes" : "No")</td>
                            <td>@field.SortOrder</td>
                            <td class="text-end">
                                <a href="/Config/CategoryFields/Edit/@field.Id" class="btn btn-sm btn-icon btn-light-warning me-2" title="Edit">
                                    <i class="bi bi-pencil fs-4"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@field.Id" method="post" style="display:inline"
                                      onsubmit="return confirm('Delete this field? This will NOT delete existing product data.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-icon btn-light-danger" title="Delete">
                                        <i class="bi bi-trash fs-4"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            if (!$.fn.DataTable.isDataTable('#fieldsTable')) {
                $('#fieldsTable').DataTable({ pageLength: 50, order: [[0, 'asc'], [5, 'asc']] });
            }
        });
    </script>
}
